<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="400.0" style="-fx-background-color: white; -fx-background-radius: 15;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fx.com/fxml/1" fx:controller="SeatMapController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label fx:id="lblEventName" text="Event Name" textFill="#1a237e">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <Label text="Please select your preferred seat" textFill="#757575" />
                    </children>
                </VBox>

                <!-- The Stage/Screen Indicator -->
                <Label alignment="CENTER" prefHeight="10.0" prefWidth="300.0" style="-fx-background-color: #E0E0E0; -fx-background-radius: 5;" text="STAGE / SCREEN" textFill="#9e9e9e">
                    <font><Font size="9.0" /></font>
                </Label>

                <!-- The Grid where buttons will be generated -->
                <GridPane fx:id="gridSeats" alignment="CENTER" hgap="10.0" vgap="10.0">
                    <!-- We will generate buttons here via Java code -->
                </GridPane>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Region prefHeight="15.0" prefWidth="15.0" style="-fx-background-color: #4CAF50; -fx-background-radius: 3;" />
                                <Label text="Available" style="-fx-font-size: 10;" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Region prefHeight="15.0" prefWidth="15.0" style="-fx-background-color: #F44336; -fx-background-radius: 3;" />
                                <Label text="Occupied" style="-fx-font-size: 10;" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <Label fx:id="lblSelectedSeat" text="Selected Seat: None" textFill="#3949AB">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>

                <Button fx:id="btnConfirm" onAction="#handleConfirm" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #1A237E; -fx-background-radius: 5;" text="Confirm Booking" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>