<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #EBEDF0;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fx.com/fxml/1" fx:controller="TicketingController">
   <children>
      <!-- Sidebar Navigation -->
      <VBox prefHeight="600.0" prefWidth="220.0" style="-fx-background-color: #1A237E;">
         <children>
            <VBox spacing="5.0" style="-fx-padding: 30 20 30 20;">
               <children>
                  <Label text="EVENT CENTER" textFill="WHITE">
                     <font><Font name="System Bold" size="18.0" /></font>
                  </Label>
               </children>
            </VBox>
            <VBox spacing="10.0" style="-fx-padding: 10 15 10 15;">
               <children>
                  <Button fx:id="btnBrowse" onAction="#handleBrowse" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #3949AB; -fx-text-fill: white; -fx-background-radius: 8;" text="  🧭  Browse Events" />
                  <Button fx:id="btnMyTickets" onAction="#handleMyTickets" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #c5cae9; -fx-background-radius: 8;" text="  🎫  My Bookings" />
                  <Button fx:id="btnMemberships" onAction="#handleShowMemberships" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #c5cae9; -fx-background-radius: 8;" text="  ⭐ Upgrade Tier" />
               </children>
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <VBox spacing="10.0" style="-fx-padding: 20 15 30 15;">
               <children>
                  <Button fx:id="btnLogout" alignment="BASELINE_LEFT" onAction="#handleLogout" style="-fx-background-color: transparent;" text="  ↳  Logout" textFill="#c5cae9" />
               </children>
            </VBox>
         </children>
      </VBox>

      <!-- Header Section -->
      <HBox alignment="CENTER_LEFT" layoutX="240.0" layoutY="25.0" prefWidth="630.0" spacing="15.0">
         <children>
            <VBox alignment="CENTER_LEFT">
               <children>
                  <Label fx:id="lblWelcome" text="Welcome, User" textFill="#1a237e">
                     <font><Font name="System Bold" size="24.0" /></font>
                  </Label>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <children>
                        <Label fx:id="lblTier" style="-fx-font-weight: bold; -fx-font-size: 11;" text="STANDARD" textFill="#3949AB" />
                        <Label text="|" textFill="#757575" />
                        <Label fx:id="lblBalance" style="-fx-font-weight: bold; -fx-font-size: 11;" text="Wallet: $0.00" textFill="#2E7D32" />
                        <Button onAction="#handleOpenTopUp" style="-fx-background-color: #2E7D32; -fx-background-radius: 20; -fx-padding: 2 8 2 8;" text="+" textFill="WHITE">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtSearch" prefHeight="35.0" prefWidth="220.0" promptText="🔍 Search events..." style="-fx-background-radius: 20; -fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 20; -fx-padding: 0 15 0 15;" />
         </children>
      </HBox>

      <!-- Main Content Area -->
      <StackPane layoutX="240.0" layoutY="100.0" prefHeight="420.0" prefWidth="630.0">
         <children>

            <!-- PANE 1: TABLE VIEW (Events and Bookings) -->
            <VBox fx:id="paneMain" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.1), 10, 0, 0, 5);">
               <children>
                  <Label fx:id="lblTableTitle" text="Upcoming Experiences" textFill="#1a237e">
                     <font><Font name="System Bold" size="18.0" /></font>
                  </Label>
                  <StackPane VBox.vgrow="ALWAYS">
                     <children>
                        <TableView fx:id="tblEvents" prefHeight="350.0">
                           <columns>
                              <TableColumn fx:id="colName" prefWidth="170.0" text="EVENT NAME" />
                              <TableColumn fx:id="colDate" prefWidth="90.0" text="DATE" />
                              <TableColumn fx:id="colVenue" prefWidth="120.0" text="VENUE" />
                              <TableColumn fx:id="colPrice" prefWidth="80.0" text="PRICE" />
                              <TableColumn fx:id="colSeats" prefWidth="100.0" text="SEATS LEFT" />
                           </columns>
                        </TableView>
                        <TableView fx:id="tblBookings" prefHeight="350.0" visible="false">
                           <columns>
                              <TableColumn fx:id="colTicketId" prefWidth="80.0" text="TICKET ID" />
                              <TableColumn fx:id="colBookedEvent" prefWidth="170.0" text="EVENT" />
                              <TableColumn fx:id="colBookedDate" prefWidth="100.0" text="DATE" />
                              <TableColumn fx:id="colBookedSeat" prefWidth="100.0" text="MY SEAT" />
                              <TableColumn fx:id="colPaid" prefWidth="110.0" text="PAID" />
                           </columns>
                        </TableView>
                     </children>
                  </StackPane>
               </children>
            </VBox>

            <!-- PANE 2: MEMBERSHIP SHOP & BANK LINKING -->
            <VBox fx:id="paneMemberships" spacing="20.0" visible="false" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.1), 10, 0, 0, 5);">
               <children>
                  <Label text="Membership Tier Shop" textFill="#1a237e">
                     <font><Font name="System Bold" size="20.0" /></font>
                  </Label>
                  <HBox spacing="15.0">
                     <children>
                        <VBox prefWidth="280.0" spacing="10.0" style="-fx-border-color: #E0E0E0; -fx-padding: 15; -fx-border-radius: 10;">
                           <children>
                              <Label text="GOLD TIER" textFill="#f39c12">
                                 <font><Font name="System Bold" size="16.0" /></font>
                              </Label>
                              <Label text="• 10% Discount on all shows" />
                              <Label style="-fx-font-weight: bold;" text="Price: $1,000.00" />
                              <Button onAction="#handleUpgradeGold" prefWidth="250.0" style="-fx-background-color: #f39c12;" text="Upgrade Now" textFill="WHITE" />
                           </children>
                        </VBox>
                        <VBox prefWidth="280.0" spacing="10.0" style="-fx-border-color: #3949AB; -fx-padding: 15; -fx-border-radius: 10;">
                           <children>
                              <Label text="ELITE TIER" textFill="#3949AB">
                                 <font><Font name="System Bold" size="16.0" /></font>
                              </Label>
                              <Label text="• 20% Discount on all shows" />
                              <Label style="-fx-font-weight: bold;" text="Price: $2,500.00" />
                              <Button onAction="#handleUpgradeElite" prefWidth="250.0" style="-fx-background-color: #3949AB;" text="Upgrade Now" textFill="WHITE" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </StackPane>

      <!-- Footer Buttons -->
      <HBox alignment="CENTER_RIGHT" layoutX="240.0" layoutY="535.0" prefWidth="630.0" spacing="15.0">
         <children>
            <Button fx:id="btnCancel" onAction="#handleCancelTicket" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: white; -fx-border-color: #EF9A9A; -fx-text-fill: #D32F2F;" text="ⓧ Cancel" visible="false" />
            <Button fx:id="btnDownload" onAction="#handleDownloadVoucher" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #f5f5f5; -fx-border-color: #E0E0E0;" text="⬇ Download" visible="false" />
            <Button fx:id="btnBook" onAction="#handleBookTicket" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #3949AB; -fx-background-radius: 5;" text="🎫 Book Selected Ticket" textFill="WHITE" />
         </children>
      </HBox>
   </children>
</AnchorPane>