<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #EBEDF0;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fx.com/fxml/1" fx:controller="TicketingController">
   <children>
      <!-- Sidebar Navigation -->
      <VBox prefHeight="600.0" prefWidth="220.0" style="-fx-background-color: #1A237E;">
         <children>
            <VBox spacing="5.0" style="-fx-padding: 30 20 30 20;">
               <children>
                  <Label text="EVENT CENTER" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  <Label text="EVENT MANAGER • ELITE TIER" textFill="#9fa8da">
                     <font>
                        <Font size="10.0" />
                     </font>
                  </Label>
               </children>
            </VBox>

            <VBox spacing="10.0" style="-fx-padding: 10 15 10 15;">
               <children>
                  <Button fx:id="btnBrowse" alignment="BASELINE_LEFT" onAction="#handleBrowse" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #3949AB; -fx-background-radius: 8;" text="  🧭  Browse Events" textFill="WHITE">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Button>
                  <Button fx:id="btnMyTickets" alignment="BASELINE_LEFT" onAction="#handleMyTickets" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-background-radius: 8;" text="  🎫  My Bookings" textFill="#c5cae9">
                     <font><Font size="13.0" /></font>
                  </Button>
               </children>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox spacing="10.0" style="-fx-padding: 20 15 30 15;">
               <children>
                  <Button alignment="BASELINE_LEFT" style="-fx-background-color: transparent;" text="  ⚙  Settings" textFill="#c5cae9" />
                  <Button alignment="BASELINE_LEFT" style="-fx-background-color: transparent;" text="  ❓  Help" textFill="#c5cae9" />
                  <Button fx:id="btnLogout" alignment="BASELINE_LEFT" onAction="#handleLogout" style="-fx-background-color: transparent;" text="  ↳  Logout" textFill="#c5cae9" />
               </children>
            </VBox>
         </children>
      </VBox>

      <!-- Header Section -->
      <HBox alignment="CENTER_LEFT" layoutX="240.0" layoutY="25.0" prefHeight="60.0" prefWidth="630.0" spacing="20.0">
         <children>
            <VBox alignment="CENTER_LEFT">
               <children>
                  <Label fx:id="lblWelcome" text="Welcome, User" textFill="#1a237e">
                     <font><Font name="System Bold" size="24.0" /></font>
                  </Label>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <children>
                        <Label fx:id="lblTier" style="-fx-font-weight: bold; -fx-font-size: 11;" text="STANDARD TIER" textFill="#3949AB" />
                        <Label text="|" textFill="#757575" />
                        <Label fx:id="lblBalance" style="-fx-font-weight: bold; -fx-font-size: 11;" text="Wallet: $0.00" textFill="#2E7D32" />
                     </children>
                  </HBox>
                  <Label fx:id="lblViewTitle" text="CURRENTLY VIEWING: ALL EVENTS" textFill="#757575">
                     <font><Font size="11.0" /></font>
                  </Label>
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtSearch" prefHeight="35.0" prefWidth="220.0" promptText="🔍 Search events or venues..." style="-fx-background-radius: 20; -fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 20; -fx-padding: 0 15 0 15;" />
         </children>
      </HBox>

      <!-- Dashboard Card -->
      <VBox layoutX="240.0" layoutY="100.0" prefHeight="420.0" prefWidth="630.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.1), 10, 0, 0, 5);">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label text="Upcoming Experiences" textFill="#1a237e">
                     <font><Font name="System Bold" size="18.0" /></font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label text="≡  🔍" textFill="#757575">
                     <font><Font size="16.0" /></font>
                  </Label>
               </children>
               <padding><Insets bottom="10.0" left="10.0" right="10.0" top="5.0" /></padding>
            </HBox>

            <TableView fx:id="tblEvents" prefHeight="350.0" prefWidth="590.0" style="-fx-background-color: transparent; -fx-border-color: transparent;">
               <columns>
                  <TableColumn fx:id="colName" prefWidth="180.0" text="EVENT NAME" />
                  <TableColumn fx:id="colDate" prefWidth="100.0" text="DATE" />
                  <TableColumn fx:id="colVenue" prefWidth="130.0" text="VENUE" />
                  <TableColumn fx:id="colPrice" prefWidth="90.0" text="PRICE" />
                  <TableColumn fx:id="colSeats" prefWidth="100.0" text="SEATS REMAINING" />
               </columns>
            </TableView>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>

      <!-- Footer Buttons -->
      <HBox alignment="CENTER_RIGHT" layoutX="240.0" layoutY="535.0" prefHeight="50.0" prefWidth="630.0" spacing="15.0">
         <children>
            <Button fx:id="btnCancel" onAction="#handleCancelTicket" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: white; -fx-border-color: #EF9A9A; -fx-border-radius: 5; -fx-text-fill: #D32F2F;" text="ⓧ  Cancel My Ticket">
               <font><Font name="System Bold" size="12.0" /></font>
            </Button>
            <Button fx:id="btnBook" onAction="#handleBookTicket" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #3949AB; -fx-background-radius: 5;" text="🎫  Book Selected Ticket" textFill="WHITE">
               <font><Font name="System Bold" size="12.0" /></font>
            </Button>
         </children>
      </HBox>
   </children>
</AnchorPane>