<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="380.0" style="-fx-background-color: white; -fx-background-radius: 15;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fx.com/fxml/1" fx:controller="TopUpController">
    <children>
        <StackPane AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>

                <!-- PANE 1: LINKING (For New Users) -->
                <VBox fx:id="paneLink" alignment="TOP_CENTER" spacing="20.0" visible="false">
                    <children>
                        <VBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="SETUP PAYMENT" textFill="#1a237e">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>
                                <Label text="Link a card to enable top-ups." textFill="#757575" />
                            </children>
                        </VBox>
                        <VBox spacing="15.0" style="-fx-background-color: #F0F2F9; -fx-padding: 20; -fx-background-radius: 10;">
                            <children>
                                <TextField fx:id="txtNewCard" prefHeight="40.0" promptText="Enter 16-Digit Card Number" />
                                <PasswordField fx:id="txtNewPin" prefHeight="40.0" promptText="Enter 4-Digit PIN" />
                            </children>
                        </VBox>
                        <Button onAction="#handleLinkCard" prefHeight="45.0" prefWidth="300.0" style="-fx-background-color: #1A237E; -fx-background-radius: 5;" text="Link Account" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                    </children>
                </VBox>

                <!-- PANE 2: TOP-UP (For Returning Users) -->
                <VBox fx:id="paneTopUp" alignment="TOP_CENTER" spacing="20.0" visible="false">
                    <children>
                        <VBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="SECURE TOP-UP" textFill="#1a237e">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>
                                <Label text="Daily Limit: $500.00" textFill="#757575" />
                            </children>
                        </VBox>
                        <VBox spacing="15.0" style="-fx-background-color: #F8F9FA; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #E0E0E0;">
                            <children>
                                <TextField fx:id="txtCardNumber" prefHeight="40.0" promptText="16-Digit Card Number" />
                                <HBox spacing="10.0">
                                    <children>
                                        <PasswordField fx:id="txtPin" prefHeight="40.0" promptText="PIN" prefWidth="100" />
                                        <TextField fx:id="txtAmount" prefHeight="40.0" promptText="Amount ($)" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <Button onAction="#handleConfirmTopUp" prefHeight="45.0" prefWidth="300.0" style="-fx-background-color: #2E7D32; -fx-background-radius: 5;" text="Confirm Payment" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                    </children>
                </VBox>

            </children>
        </StackPane>
    </children>
</AnchorPane>